{
  "name": "template-vike-lite-solid-daisyui-hono",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "yarn@4.17.1",
  "scripts": {
    "dev": "vite dev",
    "type:check": "tsc",
    "build": "yarn build:client && yarn build:server",
    "build:docker": "yarn build:client && yarn build:server:docker",
    "build:client": "vite build",
    "build:server": "vite build --ssr",
    "build:server:docker": "IS_DOCKER=true vite build --ssr",
    "prod": "NODE_ENV=production node dist/server/index.mjs",
    "preview": "NODE_ENV=production node scripts/startServerPreview.mjs",
    "lint": "eslint src/**/*.{ts,tsx} *.ts",
    "od": "yarn outdated"
  },
  "dependencies": {
    "solid-js": "^1.9.14"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.8",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@yarnpkg/sdks": "^3.3.0",
    "daisyui": "^5.6.18",
    "eslint": "^10.7.0",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-tailwindcss": "^4.2.0",
    "eslint-plugin-unicorn": "^71.1.0",
    "hono": "^4.12.30",
    "standaloner": "^0.3.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vike-lite": "^1.14.0",
    "vike-lite-solid": "^1.9.3",
    "vite": "^8.1.4",
    "vite-plugin-solid": "^2.11.12"
  },
  "files": [
    "dist"
  ]
}
